        "minimum": 0,
        "type": "integer"
      },
      "press_enter_after": {
        "default": false,
        "type": "boolean"
      },
      "text": {
        "type": "string"
      },
      "use_scancodes": {
        "default": false,
        "type": "boolean"
      }
    },
    "required": [
      "text"
