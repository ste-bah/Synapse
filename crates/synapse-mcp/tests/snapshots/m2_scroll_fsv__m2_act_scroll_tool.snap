---
{
  "description": "Scroll vertically or horizontally at the current pointer or screen point",
  "inputSchema": {
    "$defs": {
      "ActScrollPoint": {
        "additionalProperties": false,
        "properties": {
          "x": {
            "format": "int32",
            "type": "integer"
          },
          "y": {
            "format": "int32",
            "type": "integer"
          }
        },
        "required": [
          "x",
          "y"
        ],
        "type": "object"
      }
    },
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "additionalProperties": false,
    "properties": {
      "at": {
        "anyOf": [
          {
            "$ref": "#/$defs/ActScrollPoint"
          },
          {
            "type": "null"
          }
        ]
      },
      "dx": {
        "default": 0,
        "format": "int32",
        "type": "integer"
      },
      "dy": {
        "default": 0,
        "format": "int32",
        "type": "integer"
      },
      "smooth": {
        "default": false,
        "type": "boolean"
      }
    },
    "title": "ActScrollParams",
    "type": "object"
  },
  "name": "act_scroll",
  "outputSchemaRoot": {
    "additionalProperties": false,
    "required": [
      "ok",
      "dy",
      "dx",
      "smooth",
      "scrolled",
      "wheel_event_count",
      "smooth_interval_ms",
      "scheduled_smooth_total_ms",
      "backend_used",
      "elapsed_ms"
    ],
    "title": "ActScrollResponse",
    "type": "object"
  }
}
