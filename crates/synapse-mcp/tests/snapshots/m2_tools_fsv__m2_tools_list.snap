      "type": "object"
    },
    "name": "set_capture_target",
    "outputSchema": {
      "$defs": {
        "CaptureTargetWire": {
          "oneOf": [
            {
              "additionalProperties": false,
              "properties": {
                "kind": {
                  "const": "primary",
                  "type": "string"
                }
              },
              "required": [
                "kind"
              ],
              "type": "object"
            },
            {
              "additionalProperties": false,
              "properties": {
                "kind": {
                  "const": "monitor",
                  "type": "string"
                },
                "monitor_index": {
                  "format": "uint32",
                  "minimum": 0,
                  "type": "integer"
                }
              },
              "required": [
                "kind",
                "monitor_index"
              ],
              "type": "object"
            },
            {
              "additionalProperties": false,
              "properties": {
                "kind": {
                  "const": "window",
                  "type": "string"
                },
                "window_hwnd": {
