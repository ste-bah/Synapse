  {
    "description": "Apply a virtual gamepad report and optionally return it to neutral",
    "inputSchema": {
      "$defs": {
        "ActPadButton": {
          "enum": [
            "a",
            "b",
            "x",
            "y",
            "lb",
            "rb",
            "ls",
            "rs",
            "back",
            "start",
            "up",
            "down",
            "left",
            "right"
          ],
          "type": "string"
        },
        "ActPadController": {
          "enum": [
            "x360",
            "ds4"
          ],
          "type": "string"
        },
        "ActPadReport": {
          "additionalProperties": false,
          "properties": {
            "buttons": {
              "default": [],
