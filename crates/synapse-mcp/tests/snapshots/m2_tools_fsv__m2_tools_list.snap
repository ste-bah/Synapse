---
source: crates/synapse-mcp/tests/m2_tools_fsv.rs
expression: schemas
---
[
  {
    "description": "Move the pointer toward a screen, element, or track target",
    "inputSchema": {
      "$defs": {
        "ActAimElementTarget": {
          "additionalProperties": false,
          "properties": {
            "element_id": {
              "$ref": "#/$defs/ElementId"
            }
          },
          "required": [
            "element_id"
          ],
          "type": "object"
        },
        "ActAimPointTarget": {
          "additionalProperties": false,
          "properties": {
            "x": {
              "format": "int32",
              "type": "integer"
            },
            "y": {
              "format": "int32",
              "type": "integer"
            }
          },
          "required": [
            "x",
            "y"
          ],
          "type": "object"
        },
        "ActAimTarget": {
          "anyOf": [
            {
              "$ref": "#/$defs/ActAimPointTarget"
            },
            {
              "$ref": "#/$defs/ActAimElementTarget"
            },
            {
              "$ref": "#/$defs/ActAimTrackTarget"
            }
          ]
        },
        "ActAimTrackTarget": {
          "additionalProperties": false,
          "properties": {
            "track_id": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            }
          },
          "required": [
            "track_id"
          ],
          "type": "object"
        },
        "AimBackend": {
          "enum": [
            "software",
            "hardware",
            "auto"
          ],
          "type": "string"
        },
        "AimStyleParam": {
          "enum": [
            "snap",
            "flick",
            "natural",
            "track"
          ],
          "type": "string"
        },
        "ElementId": {
          "pattern": "^-?0x[0-9a-fA-F]+:[0-9a-fA-F]+$",
          "type": "string"
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "backend": {
          "$ref": "#/$defs/AimBackend",
          "default": "auto"
        },
        "deadline_ms": {
          "default": 80,
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "style": {
          "$ref": "#/$defs/AimStyleParam",
          "default": "snap"
        },
        "target": {
          "$ref": "#/$defs/ActAimTarget"
        }
      },
      "required": [
        "target"
      ],
      "title": "ActAimParams",
      "type": "object"
    },
    "name": "act_aim",
    "outputSchema": {
      "$defs": {
        "AimStyleParam": {
          "enum": [
            "snap",
            "flick",
            "natural",
            "track"
          ],
          "type": "string"
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "backend_used": {
          "type": "string"
        },
        "duration_ms": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "elapsed_ms": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "ok": {
          "type": "boolean"
        },
        "style_used": {
          "$ref": "#/$defs/AimStyleParam"
        }
      },
      "required": [
        "ok",
        "style_used",
        "duration_ms",
        "backend_used",
        "elapsed_ms"
      ],
      "title": "ActAimResponse",
      "type": "object"
    }
  },
  {
    "description": "Click a screen coordinate or UI Automation element",
    "inputSchema": {
      "$defs": {
        "ActClickElementTarget": {
          "additionalProperties": false,
          "properties": {
            "element_id": {
              "$ref": "#/$defs/ElementId"
            }
          },
          "required": [
            "element_id"
          ],
          "type": "object"
        },
        "ActClickPointTarget": {
          "additionalProperties": false,
          "properties": {
            "x": {
              "format": "int32",
              "type": "integer"
            },
            "y": {
              "format": "int32",
              "type": "integer"
            }
          },
          "required": [
            "x",
            "y"
          ],
          "type": "object"
        },
        "ActClickTarget": {
          "anyOf": [
            {
              "$ref": "#/$defs/ActClickElementTarget"
            },
            {
              "$ref": "#/$defs/ActClickPointTarget"
            }
          ]
        },
        "Backend": {
          "enum": [
            "software",
            "vigem",
            "hardware",
            "auto"
          ],
          "type": "string"
        },
        "ClickCurve": {
          "enum": [
            "natural",
            "instant",
            "linear",
            "ease_in_out"
          ],
          "type": "string"
        },
        "ClickModifier": {
          "enum": [
            "ctrl",
            "shift",
            "alt",
            "super"
          ],
          "type": "string"
        },
        "ElementId": {
          "pattern": "^-?0x[0-9a-fA-F]+:[0-9a-fA-F]+$",
          "type": "string"
        },
        "MouseButton": {
          "enum": [
            "left",
            "right",
            "middle",
            "x1",
            "x2"
          ],
          "type": "string"
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "backend": {
          "$ref": "#/$defs/Backend",
          "default": "auto"
        },
        "button": {
          "$ref": "#/$defs/MouseButton",
          "default": "left"
        },
        "clicks": {
          "default": 1,
          "format": "uint8",
          "maximum": 3,
          "minimum": 1,
          "type": "integer"
        },
        "curve": {
          "$ref": "#/$defs/ClickCurve",
          "default": "natural"
        },
        "duration_ms": {
          "default": 50,
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "modifiers": {
          "items": {
            "$ref": "#/$defs/ClickModifier"
          },
          "type": "array"
        },
        "target": {
          "$ref": "#/$defs/ActClickTarget"
        },
        "use_invoke_pattern": {
          "default": true,
          "type": "boolean"
        }
      },
      "required": [
        "target"
      ],
      "title": "ActClickParams",
      "type": "object"
    },
    "name": "act_click",
    "outputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "backend_used": {
          "type": "string"
        },
        "double_click_window_ms": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "elapsed_ms": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "inter_click_delay_ms": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "ok": {
          "type": "boolean"
        },
        "used_invoke_pattern": {
          "type": "boolean"
        }
      },
      "required": [
        "ok",
        "used_invoke_pattern",
        "backend_used",
        "double_click_window_ms",
        "inter_click_delay_ms",
        "elapsed_ms"
      ],
      "title": "ActClickResponse",
      "type": "object"
    }
  },
  {
