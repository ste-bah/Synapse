  {
    "description": "Type text through the active keyboard backend",
    "inputSchema": {
      "$defs": {
        "ElementId": {
          "pattern": "^-?0x[0-9a-fA-F]+:[0-9a-fA-F]+$",
          "type": "string"
        },
        "TypeBackend": {
          "enum": [
            "software",
            "hardware",
            "auto"
          ],
          "type": "string"
        },
        "TypeDynamics": {
          "enum": [
            "burst",
            "linear",
            "natural"
          ],
