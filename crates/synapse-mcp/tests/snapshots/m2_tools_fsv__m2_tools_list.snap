        },
        "diagnostics": {
          "$ref": "#/$defs/ObservationDiagnostics"
        },
        "elements": {
          "default": [],
          "items": {
            "$ref": "#/$defs/AccessibleNode"
          },
          "type": "array"
        },
        "entities": {
          "default": [],
          "items": {
            "$ref": "#/$defs/DetectedEntity"
          },
          "type": "array"
        },
        "focused": {
          "anyOf": [
            {
              "$ref": "#/$defs/FocusedElement"
            },
            {
              "type": "null"
            }
          ]
        },
        "foreground": {
          "$ref": "#/$defs/ForegroundContext"
        },
        "fs_recent": {
          "default": [],
          "items": {
            "$ref": "#/$defs/FsEvent"
          },
          "type": "array"
        },
        "hud": {
          "$ref": "#/$defs/HudReadings",
          "default": {
            "by_name": {}
          }
        },
        "mode": {
          "$ref": "#/$defs/PerceptionMode"
        },
        "recent_events": {
          "default": [],
          "items": {
            "$ref": "#/$defs/EventSummary"
          },
          "type": "array"
        },
        "seq": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "seq",
        "at",
        "mode",
        "foreground",
        "diagnostics"
      ],
      "title": "Observation",
      "type": "object"
    }
  },
  {
    "description": "OCR text from a screen region or visible element",
    "inputSchema": {
      "$defs": {
        "ElementId": {
          "pattern": "^-?0x[0-9a-fA-F]+:[0-9a-fA-F]+$",
          "type": "string"
        },
        "OcrBackend": {
          "enum": [
            "winrt",
            "crnn",
            "auto"
          ],
          "type": "string"
        },
        "Rect": {
          "additionalProperties": false,
          "properties": {
            "h": {
              "format": "int32",
              "type": "integer"
            },
            "w": {
              "format": "int32",
              "type": "integer"
            },
            "x": {
              "format": "int32",
              "type": "integer"
            },
            "y": {
              "format": "int32",
              "type": "integer"
            }
          },
          "required": [
            "x",
            "y",
            "w",
            "h"
          ],
          "type": "object"
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "backend": {
          "$ref": "#/$defs/OcrBackend",
          "default": "auto"
        },
        "element_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/ElementId"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "lang_hint": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "region": {
          "anyOf": [
            {
              "$ref": "#/$defs/Rect"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "ReadTextParams",
      "type": "object"
    },
    "name": "read_text",
    "outputSchema": {
      "$defs": {
        "OcrWord": {
          "additionalProperties": false,
          "properties": {
            "bbox": {
              "$ref": "#/$defs/Rect"
            },
            "confidence": {
              "format": "float",
              "type": "number"
            },
            "text": {
              "type": "string"
            }
          },
          "required": [
            "text",
            "bbox",
            "confidence"
          ],
          "type": "object"
        },
        "Rect": {
          "additionalProperties": false,
          "properties": {
            "h": {
              "format": "int32",
              "type": "integer"
            },
            "w": {
              "format": "int32",
              "type": "integer"
            },
            "x": {
              "format": "int32",
              "type": "integer"
            },
            "y": {
              "format": "int32",
              "type": "integer"
            }
          },
          "required": [
            "x",
            "y",
            "w",
            "h"
          ],
          "type": "object"
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "format": "float",
          "type": "number"
        },
        "full_text": {
          "type": "string"
        },
        "lang": {
          "type": "string"
        },
        "region": {
          "$ref": "#/$defs/Rect"
        },
        "words": {
          "items": {
            "$ref": "#/$defs/OcrWord"
          },
          "type": "array"
        }
      },
      "required": [
        "full_text",
        "words",
        "confidence",
        "region",
        "lang"
      ],
      "title": "OcrResult",
      "type": "object"
    }
  },
  {
    "description": "Release all held keyboard, mouse, and gamepad input state",
