        "released_buttons": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "released_keys": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "released_keys",
        "released_buttons",
        "neutralized_pads"
      ],
      "title": "ReleaseAllResponse",
      "type": "object"
    }
  },
  {
    "description": "Set the active capture target",
    "inputSchema": {
      "$defs": {
