          "default": null,
          "type": [
            "boolean",
            "null"
          ]
        },
        "dirty_region_only": {
          "default": null,
          "type": [
            "boolean",
            "null"
          ]
        },
        "min_update_interval_ms": {
          "default": null,
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "target": {
          "$ref": "#/$defs/CaptureTargetParam"
        }
      },
      "required": [
