---
source: crates/synapse-mcp/tests/m1_tools_fsv.rs
expression: projection
---
[
  {
    "description": "Search visible accessibility nodes and detected entities",
    "inputSchema": {
      "$defs": {
        "ElementId": {
          "pattern": "^-?0x[0-9a-fA-F]+:[0-9a-fA-F]+$",
          "type": "string"
        },
        "FindScope": {
          "enum": [
            "elements",
            "entities",
            "both"
          ],
          "type": "string"
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "automation_id": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "in_window": {
          "anyOf": [
            {
              "$ref": "#/$defs/ElementId"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "limit": {
          "default": null,
          "format": "uint",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "name_substring": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "query": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "role": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "scope": {
          "anyOf": [
            {
              "$ref": "#/$defs/FindScope"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "title": "FindParams",
      "type": "object"
    },
    "name": "find",
    "outputSchemaRoot": {
      "additionalProperties": false,
      "required": [
        "results"
      ],
      "title": "FindResponse",
      "type": "object"
    }
  },
  {
    "description": "Return server health",
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "title": "EmptyParams",
      "type": "object"
    },
    "name": "health",
    "outputSchemaRoot": {
      "additionalProperties": false,
      "required": [
        "ok",
        "version",
        "build",
        "uptime_s",
        "subsystems"
      ],
      "title": "Health",
      "type": "object"
    }
  },
  {
    "description": "Returns structured state of the focused window and surrounding context",
    "inputSchema": {
      "$defs": {
        "ObserveSlot": {
          "enum": [
            "focused",
            "elements",
            "entities",
            "hud",
            "audio",
            "events",
            "clipboard",
            "fs",
            "diagnostics"
          ],
          "type": "string"
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "depth": {
          "default": null,
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "include": {
          "items": {
            "$ref": "#/$defs/ObserveSlot"
          },
          "type": "array"
        },
        "max_elements": {
          "default": null,
          "format": "uint",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "since_event_seq": {
          "default": null,
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "title": "ObserveParams",
      "type": "object"
    },
    "name": "observe",
    "outputSchemaRoot": {
      "additionalProperties": false,
      "required": [
        "seq",
        "at",
        "mode",
        "foreground",
        "diagnostics"
      ],
      "title": "Observation",
      "type": "object"
    }
  },
  {
    "description": "OCR text from a screen region or visible element",
    "inputSchema": {
      "$defs": {
        "ElementId": {
          "pattern": "^-?0x[0-9a-fA-F]+:[0-9a-fA-F]+$",
          "type": "string"
        },
        "OcrBackend": {
          "enum": [
            "winrt",
            "crnn",
            "auto"
          ],
          "type": "string"
        },
        "Rect": {
          "additionalProperties": false,
          "properties": {
            "h": {
              "format": "int32",
              "type": "integer"
            },
            "w": {
              "format": "int32",
              "type": "integer"
            },
            "x": {
              "format": "int32",
              "type": "integer"
            },
            "y": {
              "format": "int32",
              "type": "integer"
            }
          },
          "required": [
            "x",
            "y",
            "w",
            "h"
          ],
          "type": "object"
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "backend": {
          "$ref": "#/$defs/OcrBackend",
          "default": "auto"
        },
        "element_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/ElementId"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "lang_hint": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "region": {
          "anyOf": [
            {
              "$ref": "#/$defs/Rect"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "ReadTextParams",
      "type": "object"
    },
    "name": "read_text",
    "outputSchemaRoot": {
      "additionalProperties": false,
      "required": [
        "full_text",
        "words",
        "confidence",
        "region",
        "lang"
      ],
      "title": "OcrResult",
      "type": "object"
    }
  },
  {
    "description": "Set the active capture target",
    "inputSchema": {
      "$defs": {
        "CaptureTargetParam": {
          "oneOf": [
            {
              "additionalProperties": false,
              "properties": {
                "kind": {
                  "const": "primary",
                  "type": "string"
                }
              },
              "required": [
                "kind"
              ],
              "type": "object"
            },
            {
              "additionalProperties": false,
              "properties": {
                "kind": {
                  "const": "monitor",
                  "type": "string"
                },
                "monitor_index": {
                  "format": "uint32",
                  "minimum": 0,
                  "type": "integer"
                }
              },
              "required": [
                "kind",
                "monitor_index"
              ],
              "type": "object"
            },
            {
              "additionalProperties": false,
              "properties": {
                "kind": {
                  "const": "window",
                  "type": "string"
                },
                "window_hwnd": {
                  "format": "int64",
                  "type": "integer"
                }
              },
              "required": [
                "kind",
                "window_hwnd"
              ],
              "type": "object"
            },
            {
              "additionalProperties": false,
              "properties": {
                "element_id": {
                  "$ref": "#/$defs/ElementId"
                },
                "kind": {
                  "const": "element_window",
                  "type": "string"
                }
              },
              "required": [
                "kind",
                "element_id"
              ],
              "type": "object"
            }
          ]
        },
        "ElementId": {
          "pattern": "^-?0x[0-9a-fA-F]+:[0-9a-fA-F]+$",
          "type": "string"
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "cursor_visible": {
          "default": null,
          "type": [
            "boolean",
            "null"
          ]
        },
        "dirty_region_only": {
          "default": null,
          "type": [
            "boolean",
            "null"
          ]
        },
        "min_update_interval_ms": {
          "default": null,
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "target": {
          "$ref": "#/$defs/CaptureTargetParam"
        }
      },
      "required": [
        "target"
      ],
      "title": "SetCaptureTargetParams",
      "type": "object"
    },
    "name": "set_capture_target",
    "outputSchemaRoot": {
      "additionalProperties": false,
      "required": [
        "previous",
        "current",
        "generation",
        "backend"
      ],
      "title": "SetCaptureTargetResponse",
      "type": "object"
    }
  },
  {
    "description": "Set the active perception mode",
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string"
        }
      },
      "required": [
        "mode"
      ],
      "title": "SetPerceptionModeParams",
      "type": "object"
    },
    "name": "set_perception_mode",
    "outputSchemaRoot": {
      "additionalProperties": false,
      "required": [
        "previous",
        "mode",
        "rationale"
      ],
      "title": "SetPerceptionModeResponse",
      "type": "object"
    }
  }
]
