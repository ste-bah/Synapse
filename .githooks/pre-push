#!/bin/sh
# Synapse local pre-push gate (the project's CI replacement; #351 forbids GitHub
# Actions, so "local cargo gates are source of truth"). Runs the deny-level clippy
# gate over the whole workspace before any push so [skip ci] branches can never
# push lint-red / non-compiling code — the exact class that slipped in via the
# #858 suggestion tests (clippy::field_reassign_with_default) and only surfaced at
# merge because those [skip ci] commits never ran clippy.
#
# Install once per clone:   git config core.hooksPath .githooks
# Bypass for a genuine emergency (e.g. a docs-only hotfix you cannot compile):
#   git push --no-verify   (use sparingly — you are skipping the only gate).
#
# Scope: clippy --workspace --all-targets compiles + lints everything (the full
# `cargo test --workspace` suite is intentionally NOT run here — it is minutes
# long and the agent runs it manually per doctrine D1/D5). This hook is the fast
# compile+lint backstop, not a substitute for manual FSV. The gate is deny-level:
# warning-only output is accepted, captured to a local log, and summarized so
# push output clearly distinguishes accepted warnings from blocking failures.

set -e

# Skip the gate when the push contains no Rust / Cargo changes (docs, snapshots,
# tool-result logs): clippy would just burn a minute for nothing. Compare each
# pushed local sha against its remote counterpart from stdin.
needs_gate=0
while read -r _local_ref local_sha _remote_ref remote_sha; do
  # Deleted branch (local_sha all zeros) — nothing to check.
  case "$local_sha" in *[!0]*) : ;; *) continue ;; esac
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ] || [ -z "$remote_sha" ]; then
    range="$local_sha"            # new branch: inspect the whole commit
    diff_base=$(git rev-list --max-parents=0 "$local_sha" | tail -1)
    range="$diff_base..$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi
  if git diff --name-only "$range" 2>/dev/null | grep -qE '\.rs$|(^|/)Cargo\.(toml|lock)$'; then
    needs_gate=1
  fi
done

if [ "$needs_gate" -eq 0 ]; then
  echo "pre-push: no Rust/Cargo changes in this push — skipping clippy gate."
  exit 0
fi

echo "pre-push: running local clippy gate (cargo clippy --workspace --all-targets) ..."
log_dir=$(git rev-parse --git-path synapse-pre-push-logs 2>/dev/null || printf '%s' "${TMPDIR:-/tmp}")
mkdir -p "$log_dir"
log_path="$log_dir/clippy-$(date +%Y%m%dT%H%M%S)-$$.log"

if cargo clippy --workspace --all-targets >"$log_path" 2>&1; then
  warning_count=$(grep -c '^warning:' "$log_path" 2>/dev/null || true)
  warning_count=${warning_count:-0}
  if [ "$warning_count" -gt 0 ]; then
    echo "pre-push: clippy gate green with ${warning_count} accepted warning lines; deny-level failures=0."
    echo "pre-push: full clippy log: $log_path"
  else
    rm -f "$log_path"
    echo "pre-push: clippy gate green (0 warnings)."
  fi
else
  status=$?
  echo ""
  echo "pre-push: BLOCKED — clippy gate failed. Full clippy log: $log_path"
  echo "pre-push: first 240 log lines follow:"
  sed -n '1,240p' "$log_path" || true
  total_lines=$(wc -l <"$log_path" 2>/dev/null | tr -d ' ' || true)
  total_lines=${total_lines:-0}
  if [ "$total_lines" -gt 240 ]; then
    echo "pre-push: output truncated; inspect the full log above for all diagnostics."
  fi
  echo ""
  echo "pre-push: BLOCKED — clippy gate failed. Fix the lint/build errors above, or"
  echo "          re-run with 'git push --no-verify' only if this is a genuine"
  echo "          non-compiling emergency. Local cargo gates are the source of truth (#351)."
  exit "$status"
fi
exit 0
