{
  "manifest_version": 3,
  "name": "Synapse Chrome Bridge",
  "description": "Local Synapse bridge for normal-profile Chrome tab control through direct localhost WebSocket.",
  "version": "0.1.1",
  "minimum_chrome_version": "125",
  "key": "",
  "permissions": [
    "alarms",
    "cookies",
    "debugger",
    "downloads",
    "management",
    "scripting",
    "storage",
    "tabs",
    "webRequest",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:7700/*"
  ],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  }
}
