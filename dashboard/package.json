{
  "name": "@synapse/command-center-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "check": "bun run scripts/check-dashboard-charter.ts",
    "dev": "vite --host 127.0.0.1",
    "storybook": "storybook dev -p 6006 --host 127.0.0.1 --no-open",
    "build:storybook": "storybook build --quiet -o storybook-static",
    "test:coverage": "bun run scripts/check-story-coverage.ts",
    "test:visual": "playwright test --config playwright.visual.config.ts tests/storybook-visual.spec.ts",
    "test:visual:update": "playwright test --config playwright.visual.config.ts tests/storybook-visual.spec.ts --update-snapshots",
    "test:a11y": "playwright test --config playwright.visual.config.ts tests/storybook-a11y.spec.ts"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.13",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "react": "19",
    "react-dom": "19",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@playwright/test": "1.60.0",
    "@storybook/addon-a11y": "9.1.20",
    "@storybook/react-vite": "9.1.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "storybook": "9.1.20",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "7.3.5"
  }
}
