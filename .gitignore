.claude/settings.local.json
docs2/

# CI workflows, internal agent doctrine, and private working state are not
# part of the public repo.
/.github/
/AGENTS.md
/STATE/
/state/

/target/
# Catch ad-hoc target dirs used for split-profile installs / release builds
# (see docs/dev-host-hygiene.md release-build recipe).
/target-*/
**/*.rs.bk

/dashboard/node_modules/
/dashboard/storybook-static/
/dashboard/test-results/
/dashboard/playwright-report/
/dashboard/blob-report/

.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
*.iml

.DS_Store
Thumbs.db

.env
.env.*
!.env.example

synapse.log
crashes/

*.snap.new
*.pending-snap
tracing-*.log

# Ephemeral operator-run output (see docs/dev-host-hygiene.md).
# Canonical locations are `.runs/<id>/` and `%LOCALAPPDATA%\synapse\runs\`;
/*.log
/*.ndjson
/.runs/

# Criterion/critcmp benchmark exports are regenerated and stored off-tree.
/bench_results/

# cargo-fuzz generated outputs; commit harnesses and locks, not run products.
/fuzz/artifacts/
/fuzz/coverage/
/fuzz/corpus/
/fuzz/target/

# Playwright MCP session artifacts (console logs, page snapshots).
.playwright-mcp/

# Scratch / investigation working state — never part of the repo.
/tmp/
/manual-fsv-tmp/

# synapse-update.ps1 keep-current workflow: run it daily (pull -> rebuild ->
# reconnect). The script writes its build/run logs off-tree
# (%LOCALAPPDATA%\synapse\logs); ignore any local copies so daily runs never
# dirty git status. The script itself IS committed; its run products are not.
/synapse-update-*.log
/synapse-update.log

# Vendored Calyx nested workspace build artifacts (docs/calyx/)
/calyx/target/
