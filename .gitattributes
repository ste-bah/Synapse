# Repo-wide line-ending policy (#1697).
#
# Keep source, scripts, docs, and checked-in text artifacts LF in both the index
# and the working tree, even on Windows with core.autocrlf=true. This prevents
# conversion-warning churn while keeping POSIX hooks executable.
* text=auto eol=lf

# Executable scripts and local Git hooks.
*.sh text eol=lf
*.bash text eol=lf
*.ps1 text eol=lf
*.psm1 text eol=lf
*.psd1 text eol=lf
.githooks/* text eol=lf

# Source, manifests, lockfiles, docs, and text snapshots.
*.rs text eol=lf
*.cu text eol=lf
*.toml text eol=lf
*.lock text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.snap text eol=lf
*.mt text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Windows-only project/script formats that require CRLF semantics.
*.bat text eol=crlf
*.cmd text eol=crlf
*.sln text eol=crlf

# Binary and generated assets: never normalize or diff as text.
*.bin binary -eol
*.png binary -eol
*.jpg binary -eol
*.jpeg binary -eol
*.gif binary -eol
*.webp binary -eol
*.ico binary -eol
*.wav binary -eol
*.mp3 binary -eol
*.mp4 binary -eol
*.pdf binary -eol
*.zip binary -eol
*.7z binary -eol
*.gz binary -eol
*.zst binary -eol
*.onnx binary -eol
*.exe binary -eol
*.dll binary -eol
*.pdb binary -eol

# Checked-in generated dashboard bundle: preserve producer bytes exactly.
dashboard/dist/** -text -eol
